---
import Layout from '../layouts/Layout.astro'

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/')

const schedule = [
  { week: 1,  topic: 'Course intro · Pod formation · Git workflow · Tour of the starter app', due: 'Reflection 1' },
  { week: 2,  topic: 'Bug sprint: navigation, composables, ViewModel, coroutines · First ViewModel test', due: 'Reflection 2' },
  { week: 3,  topic: 'Create Account from wireframes · Retrofit + Kotlin Serialization · POST /users + /tokens', due: 'Reflection 3' },
  { week: 4,  topic: 'DataStore · OkHttp auth interceptor · Token refresh · MediaRepository interface', due: 'Reflection 4' },
  { week: 5,  topic: 'Search: LazyColumn · GET /media · MockK for ViewModel testing', due: 'Reflection 5' },
  { week: 6,  topic: 'Library: POST/PUT/DELETE /library · Optimistic updates', due: 'Reflection 6' },
  { week: 7,  topic: 'Media detail: navigation with typed arguments · Loading and error states', due: 'Reflection 7' },
  { week: 8,  topic: 'Reviews: CRUD reviews · Composable extraction · Compose UI testing', due: 'Reflection 8' },
  { week: 9,  topic: 'Lightning Exploration: in-class build session', due: 'Reflection 9', highlight: true },
  { week: 10, topic: 'Accessibility: TalkBack + WCAG · User profile: GET/PUT /users/me · Edit Profile', due: 'Reflection 10' },
  { week: 11, topic: 'Social: followers, following, activity feed · Bonus feature assignments announced', due: 'Reflection 11' },
  { week: 12, topic: 'Bonus feature sprint (week 1)', due: 'Reflection 12' },
  { week: 13, topic: 'Bonus feature sprint (week 2) · App polish · Lightning Exploration presentations · Course closing', due: 'Final App · Final Reflection', highlight: true },
]

const methods = [
  {
    icon: '🫂',
    title: 'Development Pods',
    desc: 'You work in a pod of 3. Each student builds their own app — this is not a group project. The pod exists so you have people to think alongside, ask questions of, and review code with.',
  },
  {
    icon: '✍️',
    title: 'Weekly Reflections',
    desc: 'At the end of each class, you spend 15 minutes writing about what you shipped, one concept that clicked, and a code review you left for a pod mate. Submitted before you leave — no homework.',
  },
  {
    icon: '🔍',
    title: 'Code Reviews',
    desc: 'Each week you open a pull request and your pod mates review it on GitHub. "Looks good!" is not a review. A good review asks questions, spots potential bugs, or suggests a cleaner approach.',
  },
  {
    icon: '⚡',
    title: 'Bonus Feature',
    desc: 'In weeks 12–13, you implement a feature unique to your app — assigned by the instructor based on your progress through the semester. This is the main individual assessment.',
  },
  {
    icon: '🌩️',
    title: 'Lightning Explorations',
    desc: 'Mid-semester your pod explores an alternative mobile platform (iOS/Swift, React Native, Flutter, etc.). Week 9: build something. Week 13: present what was surprisingly easy and surprisingly hard.',
  },
]

const outcomes = [
  'Build and ship a complete Android app using Jetpack Compose',
  'Apply MVVM architecture and object-oriented design patterns',
  'Navigate a multi-screen app using Jetpack Navigation with typed arguments',
  'Explain and apply mobile design principles including accessibility (TalkBack, WCAG)',
  'Make authenticated HTTP requests to a REST API with Kotlin coroutines',
  'Persist data using Room and DataStore for secure credential storage',
  'Use git to manage code and submit work via pull requests',
  'Conduct substantive peer code reviews within your development pod',
  'Read unfamiliar code, diagnose bugs, and fix them with confidence',
]

const grading = [
  { item: '12 Weekly Reflections (25 pts each)', points: 300 },
  { item: 'Core App Final Submission (incl. Final Reflection)', points: 200 },
  { item: 'Bonus Feature', points: 100 },
  { item: 'Lightning Exploration', points: 60 },
]
const total = grading.reduce((s, g) => s + g.points, 0)
---

<Layout title="ICS342 — Mobile Application Development">

  <!-- Hero -->
  <section class="bg-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-android/10 border border-android/20 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-android animate-pulse"></span>
          <span class="text-android text-sm font-mono font-medium">Metropolitan State University</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
          Mobile Application<br/>
          <span class="text-android">Development</span>
        </h1>
        <p class="mt-6 text-lg text-slate-300 leading-relaxed max-w-2xl">
          Build and ship a real Android app over 13 weeks. Learn Jetpack Compose, MVVM, REST APIs,
          authentication, and modern Android development — by actually writing the code.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${base}api/`}
             class="inline-flex items-center gap-2 bg-android text-slate-900 font-semibold px-5 py-2.5 rounded-lg hover:bg-android/90 transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>
            API Reference
          </a>
          <a href={`${base}wireframes/`}
             class="inline-flex items-center gap-2 bg-slate-800 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-slate-700 transition-colors text-sm border border-slate-700">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3h3m-3 3H9m1.5-12H9"/></svg>
            App Wireframes
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick stats -->
  <section class="bg-slate-800 text-slate-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-android shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
          <span>Metropolitan State University</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-android shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>13 weeks</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-android shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/></svg>
          <span>4 credits</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-android shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3h3m-3 3H9"/></svg>
          <span>Prerequisite: ICS 141</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900">About this course</h2>
      <p class="mt-4 text-slate-600 leading-relaxed">
        ICS342 is built around shipping a real application. Rather than quizzes and traditional assignments,
        your learning is demonstrated through the code you write, the reviews you leave for pod mates,
        and the reflections you write at the end of each class session.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        By the end of the course you'll have built a complete Media Tracker app — a real, working Android
        application that talks to a real REST API. You'll understand every line of code you wrote and be
        able to explain the architectural decisions behind it.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-10">How the course works</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {methods.map(m => (
          <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm">
            <div class="text-2xl mb-3">{m.icon}</div>
            <h3 class="font-semibold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-slate-900 mb-8">Weekly Topics</h2>
    <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-900 text-slate-300">
            <th class="px-4 py-3 text-left font-medium w-16">Week</th>
            <th class="px-4 py-3 text-left font-medium">Topic</th>
            <th class="px-4 py-3 text-left font-medium w-36">Due</th>
          </tr>
        </thead>
        <tbody>
          {schedule.map((row, i) => (
            <tr class={`border-t border-slate-100 ${row.highlight ? 'bg-android/5' : i % 2 === 0 ? 'bg-white' : 'bg-slate-50'} hover:bg-android/5 transition-colors`}>
              <td class="px-4 py-3 font-mono text-slate-500 text-center">{row.week}</td>
              <td class="px-4 py-3 text-slate-700">{row.topic}</td>
              <td class="px-4 py-3 text-slate-500 text-xs">{row.due}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Learning outcomes + Grading -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Outcomes -->
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Learning outcomes</h2>
          <ul class="space-y-3">
            {outcomes.map(o => (
              <li class="flex items-start gap-3 text-slate-700 text-sm leading-relaxed">
                <svg class="w-4 h-4 text-android shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                {o}
              </li>
            ))}
          </ul>
        </div>
        <!-- Grading -->
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Grading</h2>
          <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
              <tbody>
                {grading.map((g, i) => (
                  <tr class={`border-t border-slate-100 ${i === 0 ? 'border-0' : ''}`}>
                    <td class="px-5 py-3.5 text-slate-700">{g.item}</td>
                    <td class="px-5 py-3.5 text-right font-mono text-slate-900 font-medium">{g.points}</td>
                  </tr>
                ))}
              </tbody>
              <tfoot>
                <tr class="bg-slate-900 border-t-2 border-slate-700">
                  <td class="px-5 py-3.5 text-white font-semibold">Total</td>
                  <td class="px-5 py-3.5 text-right font-mono text-android font-bold">{total}</td>
                </tr>
              </tfoot>
            </table>
          </div>
          <div class="mt-6 p-4 bg-android/10 border border-android/20 rounded-lg text-sm text-slate-700">
            <p class="font-medium text-slate-900 mb-1">No textbook required.</p>
            The primary reference is the official Android developer documentation at{' '}
            <a href="https://developer.android.com" target="_blank" rel="noopener" class="text-android hover:underline font-mono">developer.android.com</a>.
            Additional resources are linked in D2L.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- API & Wireframes CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">Developer resources</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <a href={`${base}api/`} class="group block bg-slate-900 rounded-xl p-7 hover:bg-slate-800 transition-colors">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-android font-mono text-xs font-medium uppercase tracking-wide mb-2">REST API</p>
            <h3 class="text-white font-semibold text-lg">API Reference</h3>
            <p class="text-slate-400 text-sm mt-2 leading-relaxed">
              Full OpenAPI 3.0 documentation for the Media Tracker API — endpoints, request bodies, response schemas, and auth flows.
            </p>
          </div>
          <svg class="w-5 h-5 text-slate-600 group-hover:text-android transition-colors shrink-0 mt-1 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
        </div>
      </a>
      <a href={`${base}wireframes/`} class="group block bg-slate-900 rounded-xl p-7 hover:bg-slate-800 transition-colors">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-android font-mono text-xs font-medium uppercase tracking-wide mb-2">UI Design</p>
            <h3 class="text-white font-semibold text-lg">App Wireframes</h3>
            <p class="text-slate-400 text-sm mt-2 leading-relaxed">
              Interactive wireframes for every screen in the Media Tracker app — your implementation guide for building the Android UI.
            </p>
          </div>
          <svg class="w-5 h-5 text-slate-600 group-hover:text-android transition-colors shrink-0 mt-1 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
        </div>
      </a>
    </div>
  </section>

</Layout>
