---
import Layout from '../../layouts/Layout.astro'
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/')
const src = `${base}wireframes.html`
---

<Layout title="App Wireframes — ICS342" fullPage={true}>
  <div class="flex flex-col h-full">
    <!-- Header bar -->
    <div class="bg-slate-800 border-b border-slate-700 px-4 sm:px-6 py-3 flex items-center gap-4 shrink-0">
      <div class="min-w-0">
        <h1 class="text-white font-semibold text-sm leading-tight">App Wireframes</h1>
        <p class="text-slate-400 text-xs mt-0.5 hidden sm:block">
          Interactive mockups for every screen in the Media Tracker app
        </p>
      </div>
      <div class="flex items-center gap-2 ml-auto shrink-0">
        <a
          href={`${base}api/`}
          class="px-3 py-1.5 text-xs text-slate-300 hover:text-white hover:bg-slate-700 rounded-md transition-colors border border-slate-600"
        >
          API Docs
        </a>
        <a
          href={src}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs bg-android text-slate-900 font-medium rounded-md hover:bg-android/90 transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          </svg>
          Full screen
        </a>
      </div>
    </div>
    <!-- Wireframes iframe -->
    <iframe
      src={src}
      title="Media Tracker App Wireframes"
      class="flex-1 border-0 w-full"
      loading="eager"
    />
  </div>
</Layout>
