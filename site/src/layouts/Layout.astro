---
interface Props {
  title: string
  description?: string
  fullPage?: boolean
}
const { title, description = 'ICS342 — Mobile Application Development at Metropolitan State University.', fullPage = false } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/')
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body class={`bg-white font-sans antialiased pt-14 ${fullPage ? 'overflow-hidden h-full' : ''}`}>
    <nav class="fixed top-0 left-0 right-0 z-50 bg-slate-900 border-b border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href={base} class="flex items-center gap-2.5 text-white hover:text-android transition-colors">
            <span class="text-android font-mono font-medium text-sm">ICS342</span>
            <span class="text-slate-400 text-sm hidden sm:inline">Media Tracker API</span>
          </a>
          <div class="flex items-center gap-1">
            <a href={`${base}api/`} class="px-3 py-1.5 text-sm text-slate-300 hover:text-white hover:bg-slate-800 rounded-md transition-colors">
              API Docs
            </a>
            <a href={`${base}wireframes/`} class="px-3 py-1.5 text-sm text-slate-300 hover:text-white hover:bg-slate-800 rounded-md transition-colors">
              Wireframes
            </a>
            <a href="https://github.com/benjamincassidy/media-tracker-api" target="_blank" rel="noopener" class="ml-1 px-3 py-1.5 text-sm text-slate-300 hover:text-white hover:bg-slate-800 rounded-md transition-colors flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main class={fullPage ? 'h-[calc(100vh-56px)]' : ''}>
      <slot />
    </main>

    {!fullPage && (
      <footer class="bg-slate-900 text-slate-400 mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
          <div class="flex flex-col sm:flex-row justify-between gap-4">
            <div>
              <p class="text-white font-medium">ICS342 — Mobile Application Development</p>
              <p class="text-sm mt-1">Metropolitan State University</p>
            </div>
            <div class="flex flex-col gap-1 text-sm">
              <a href={`${base}api/`} class="hover:text-white transition-colors">API Reference</a>
              <a href={`${base}wireframes/`} class="hover:text-white transition-colors">Wireframes</a>
              <a href="https://developer.android.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">Android Docs</a>
            </div>
          </div>
          <p class="text-xs mt-8 text-slate-600">Metropolitan State University · Saint Paul, MN</p>
        </div>
      </footer>
    )}
  </body>
</html>
