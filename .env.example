# Copy this file to .env and fill in your project values.
# Never commit .env to version control.

# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret-key>

# Used by the Supabase CLI to link and manage the remote project
SUPABASE_PROJECT_REF=<your-project-ref>
SUPABASE_DB_PASSWORD=<your-database-password>

# Personal access token for CI deploys — generate at https://supabase.com/dashboard/account/tokens
# Add as a GitHub Actions secret (SUPABASE_ACCESS_TOKEN), not in .env on dev machines
SUPABASE_ACCESS_TOKEN=<your-personal-access-token>
